{
  "$schema": "../../schemas/agent-project.schema.json",
  "schemaVersion": "agenty.dev/agent-project/v1",
  "kind": "AgentProject",
  "metadata": {
    "id": "starter-agent",
    "name": "Starter Agent",
    "description": "Runtime-neutral Agenty starter manifest.",
    "version": "0.1.0",
    "tags": ["starter", "agent-app"]
  },
  "runtimes": [
    {
      "id": "default-runtime",
      "adapter": "custom",
      "entrypoint": "src/agent.ts",
      "capabilities": ["chat", "tools", "structured-output"]
    }
  ],
  "skills": [
    {
      "id": "starter-skill",
      "source": { "type": "local", "value": "skills/starter/SKILL.md" },
      "enabled": true,
      "runtimeIds": ["default-runtime"]
    }
  ],
  "tools": [
    {
      "id": "read-project-status",
      "description": "Read project status without changing state.",
      "inputSchema": { "type": "object", "additionalProperties": false },
      "risk": "read",
      "approval": { "required": false },
      "runtimeIds": ["default-runtime"]
    },
    {
      "id": "publish-artifact",
      "description": "Publish an approved artifact.",
      "inputSchema": {
        "type": "object",
        "required": ["artifactId"],
        "properties": { "artifactId": { "type": "string" } }
      },
      "risk": "write",
      "approval": { "required": true, "policyId": "publish-approval" },
      "runtimeIds": ["default-runtime"]
    }
  ],
  "connectors": [
    {
      "id": "project-api",
      "kind": "api",
      "auth": { "type": "api-key", "env": ["PROJECT_API_KEY"] },
      "scopes": ["project:read"]
    }
  ],
  "policies": {
    "defaultToolMode": "allow-read",
    "approvals": [
      {
        "id": "publish-approval",
        "when": { "risks": ["write", "irreversible"], "toolIds": ["publish-artifact"] },
        "approvers": ["user"],
        "expiresInSeconds": 900
      }
    ]
  },
  "evals": [
    {
      "id": "manifest-smoke",
      "type": "fixture",
      "path": "evals/manifest-smoke.json",
      "threshold": 1
    }
  ],
  "ui": {
    "shell": "chat-artifact",
    "surfaces": ["sidebar", "chat", "artifact", "connectors"],
    "composer": { "owner": "parent-shell" }
  },
  "provenance": {
    "createdAt": "2026-07-15T00:00:00.000Z",
    "updatedAt": "2026-07-15T00:00:00.000Z",
    "generator": "@agenty/cli",
    "source": { "type": "template", "uri": "registry:agent-app" },
    "revision": "template-v1"
  }
}
