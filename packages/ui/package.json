{
  "name": "@agents-sdk/ui",
  "version": "0.1.0",
  "description": "Adapter-light React primitives for inspectable agent applications.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agents-sdk/agents-sdk.git",
    "directory": "packages/ui"
  },
  "homepage": "https://agents-sdk.com",
  "bugs": {
    "url": "https://github.com/agents-sdk/agents-sdk/issues"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./artifact-spec": {
      "types": "./dist/artifact-spec.d.ts",
      "import": "./dist/artifact-spec.js",
      "default": "./dist/artifact-spec.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "lucide-react": ">=0.400.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "lucide-react": "^0.525.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
