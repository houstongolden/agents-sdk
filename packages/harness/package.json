{
  "name": "@agents-sdk/harness",
  "version": "0.1.0",
  "private": true,
  "description": "Deterministic acceptance harness for Agents SDK contracts.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agents-sdk/agents-sdk.git",
    "directory": "packages/harness"
  },
  "homepage": "https://agents-sdk.com",
  "bugs": {
    "url": "https://github.com/agents-sdk/agents-sdk/issues"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "type": "module",
  "main": "./dist/index.js",
