{
  "name": "@agents-sdk/cli",
  "version": "0.1.0",
  "description": "Copy-owned component installer for Agents SDK.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agents-sdk/agents-sdk.git",
    "directory": "packages/cli"
  },
  "homepage": "https://agents-sdk.com",
  "bugs": {
    "url": "https://github.com/agents-sdk/agents-sdk/issues"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "agents": "./dist/bin.js",
    "agents-sdk": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "registry"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/prepare-assets.mjs",
    "test": "node scripts/prepare-assets.mjs && vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agents-sdk/core": "workspace:*"
  },
  "devDependencies": {
    "@agents-sdk/ui": "workspace:*",
    "@types/node": "^26.1.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "lucide-react": "^1.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
