{
  "name": "@agents-sdk/core",
  "version": "0.1.0",
  "description": "Registry, installation, and safety contracts for Agents SDK.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agents-sdk/agents-sdk.git",
    "directory": "packages/core"
  },
  "homepage": "https://agents-sdk.com",
  "bugs": {
    "url": "https://github.com/agents-sdk/agents-sdk/issues"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
