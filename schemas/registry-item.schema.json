{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agents-sdk.com/schemas/registry-item/v1.json",
  "title": "Agents SDK registry item",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "name",
    "type",
    "title",
    "description",
    "version",
    "maturity",
    "provenance",
    "examples",
    "compatibility",
    "security",
    "accessibility",
    "registryDependencies",
    "dependencies",
    "devDependencies",
    "files",
    "documentation",
    "test"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": "agents-sdk.com/registry-item/v1" },
    "name": { "$ref": "#/$defs/name" },
    "type": { "enum": ["component", "pattern", "template", "example"] },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?$" },
    "maturity": { "enum": ["experimental", "preview", "stable"] },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "license", "reviewedAt"],
      "properties": {
        "source": { "type": "string", "minLength": 1 },
        "license": { "type": "string", "minLength": 1 },
        "reviewedAt": { "type": "string", "format": "date" }
      }
    },
    "examples": { "type": "array", "items": { "$ref": "#/$defs/name" } },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node", "packages"],
      "properties": {
        "node": { "type": "string", "pattern": "^>=\\d+$" },
        "react": { "type": "string", "pattern": "^>=\\d+$" },
        "packages": { "$ref": "#/$defs/packageMap" }
      }
    },
    "security": { "$ref": "#/$defs/notes" },
    "accessibility": { "$ref": "#/$defs/notes" },
    "registryDependencies": { "type": "array", "items": { "$ref": "#/$defs/name" } },
    "dependencies": { "$ref": "#/$defs/packageMap" },
    "devDependencies": { "$ref": "#/$defs/packageMap" },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source", "target", "role"],
        "properties": {
          "source": { "$ref": "#/$defs/path" },
          "target": { "$ref": "#/$defs/path" },
          "role": { "enum": ["source", "test", "docs", "config", "example"] }
        }
      }
    },
    "documentation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "whenToUse", "whenNotToUse", "tradeoffs"],
      "properties": {
        "path": { "$ref": "#/$defs/path" },
        "whenToUse": { "type": "string", "minLength": 1 },
        "whenNotToUse": { "type": "string", "minLength": 1 },
        "tradeoffs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "test": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "paths"],
      "properties": {
        "command": { "type": "string", "minLength": 1 },
        "paths": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/path" } }
      }
    }
  },
  "$defs": {
    "name": { "type": "string", "pattern": "^[a-z][a-z0-9-]{1,62}$" },
    "path": { "type": "string", "minLength": 1 },
    "packageMap": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 }
    },
    "notes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["notes"],
      "properties": {
        "notes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
