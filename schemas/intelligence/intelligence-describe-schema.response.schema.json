{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "anyOf": [
    {
      "type": "object",
      "properties": {
        "requestId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$" },
        "data": {
          "type": "object",
          "properties": {
            "manifests": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "schemaVersion": {
                    "type": "string",
                    "const": "houston.dev/intelligence-manifest/v0.1"
                  },
                  "kind": { "type": "string", "const": "IntelligenceManifest" },
                  "metadata": {
                    "type": "object",
                    "properties": {
                      "id": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{1,127}$" },
                      "issuerId": { "type": "string", "pattern": "^[a-z][a-z0-9-]{0,62}$" },
                      "app": { "type": "string", "pattern": "^[a-z][a-z0-9-]{0,62}$" },
                      "environment": { "type": "string", "pattern": "^[a-z][a-z0-9-]{0,62}$" },
                      "version": {
                        "type": "string",
                        "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?$"
                      },
                      "generatedAt": {
                        "type": "string",
                        "format": "date-time",
                        "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
                      }
                    },
                    "required": ["id", "issuerId", "app", "environment", "version", "generatedAt"],
                    "additionalProperties": false
                  },
                  "resourceTypes": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "key": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{1,127}$" },
                        "urnResourceType": {
                          "type": "string",
                          "pattern": "^[a-z][a-z0-9._-]{1,127}$"
                        },
                        "app": { "type": "string", "pattern": "^[a-z][a-z0-9-]{0,62}$" },
                        "lifecycle": {
                          "type": "string",
                          "enum": ["experimental", "active", "deprecated"]
                        },
                        "relations": {
                          "type": "array",
                          "items": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{1,127}$" }
                        },
                        "deletion": {
                          "type": "string",
                          "enum": ["cascade_derived", "retain_tombstone", "app_managed"]
                        },
                        "manifestVersion": { "type": "string", "minLength": 1 }
                      },
                      "required": [
                        "key",
                        "urnResourceType",
                        "app",
                        "lifecycle",
                        "relations",
                        "deletion",
                        "manifestVersion"
                      ],
                      "additionalProperties": false
                    }
                  },
                  "fieldDefinitions": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "resourceType": {
                          "type": "string",
                          "pattern": "^[a-z][a-z0-9._-]{1,127}$"
                        },
                        "fieldPath": { "type": "string", "pattern": "^(?:\\/(?:[^~/]|~[01])*)*$" },
                        "semanticType": {
                          "type": "string",
                          "pattern": "^[a-z][a-z0-9._-]{1,127}$"
                        },
                        "aliases": {
                          "type": "array",
                          "items": { "type": "string", "minLength": 1 }
                        },
                        "sensitivity": {
                          "type": "string",
                          "enum": [
                            "public",
                            "workspace_private",
                            "client_confidential",
                            "restricted",
                            "prohibited_from_ai"
                          ]
                        },
                        "index": {
                          "type": "array",
                          "items": {
                            "type": "string",
                            "enum": ["exact", "lexical", "semantic", "faceted", "relationship"]
                          }
                        },
                        "pipeline": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{1,127}$" },
                        "retentionDays": {
                          "type": "integer",
                          "exclusiveMinimum": 0,
                          "maximum": 9007199254740991
                        },
                        "modelPolicy": {
                          "type": "string",
                          "enum": ["local_only", "redacted_cloud", "allowed_cloud", "no_ai"]
                        },
                        "excluded": { "default": false, "type": "boolean" }
                      },
                      "required": [
                        "resourceType",
                        "fieldPath",
                        "semanticType",
                        "aliases",
                        "sensitivity",
                        "index",
                        "modelPolicy",
                        "excluded"
                      ],
                      "additionalProperties": false
                    }
                  },
                  "policies": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "schemaVersion": {
                          "type": "string",
                          "const": "houston.dev/intelligence/v0.1"
                        },
                        "id": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{1,127}$" },
                        "version": { "type": "string", "minLength": 1 },
                        "sensitivity": {
                          "type": "string",
                          "enum": [
                            "public",
                            "workspace_private",
                            "client_confidential",
                            "restricted",
                            "prohibited_from_ai"
                          ]
                        },
                        "modelPolicy": {
                          "type": "string",
                          "enum": ["local_only", "redacted_cloud", "allowed_cloud", "no_ai"]
                        },
                        "allowedPurposes": {
                          "minItems": 1,
                          "type": "array",
                          "items": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{1,127}$" }
                        },
                        "consent": {
                          "type": "string",
                          "enum": ["not_required", "required", "verified"]
                        },
                        "retention": {
                          "type": "object",
                          "properties": {
                            "days": {
                              "type": "integer",
                              "exclusiveMinimum": 0,
                              "maximum": 9007199254740991
                            },
                            "legalHoldAware": { "type": "boolean" }
                          },
                          "required": ["legalHoldAware"],
                          "additionalProperties": false
                        },
                        "deletionBehavior": {
                          "type": "string",
                          "enum": ["cascade", "cryptographic_erasure", "tombstone_then_purge"]
                        }
                      },
                      "required": [
                        "schemaVersion",
                        "id",
                        "version",
                        "sensitivity",
                        "modelPolicy",
                        "allowedPurposes",
                        "consent",
                        "retention",
                        "deletionBehavior"
                      ],
                      "additionalProperties": false
                    }
                  }
                },
                "required": [
                  "schemaVersion",
                  "kind",
                  "metadata",
                  "resourceTypes",
                  "fieldDefinitions",
                  "policies"
                ],
                "additionalProperties": false
              }
            }
          },
          "required": ["manifests"],
          "additionalProperties": false
        },
        "warnings": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "page": {
          "type": "object",
          "properties": {
            "nextCursor": { "type": "string", "minLength": 1 },
            "hasMore": { "type": "boolean" }
          },
          "required": ["hasMore"],
          "additionalProperties": false
        }
      },
      "required": ["requestId", "data", "page"],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "requestId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$" },
        "error": {
          "type": "object",
          "properties": {
            "code": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{1,127}$" },
            "message": { "type": "string", "minLength": 1 },
            "retryable": { "type": "boolean" },
            "field": { "type": "string", "pattern": "^(?:\\/(?:[^~/]|~[01])*)*$" },
            "details": {
              "type": "object",
              "propertyNames": { "type": "string" },
              "additionalProperties": { "$ref": "#/$defs/__schema0" }
            }
          },
          "required": ["code", "message", "retryable"],
          "additionalProperties": false
        }
      },
      "required": ["requestId", "error"],
      "additionalProperties": false
    }
  ],
  "$defs": {
    "__schema0": {
      "anyOf": [
        { "type": "string" },
        { "type": "number" },
        { "type": "boolean" },
        { "type": "null" },
        { "type": "array", "items": { "$ref": "#/$defs/__schema0" } },
        {
          "type": "object",
          "propertyNames": { "type": "string" },
          "additionalProperties": { "$ref": "#/$defs/__schema0" }
        }
      ]
    }
  }
}
