{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schemaVersion": { "type": "string", "const": "houston.dev/intelligence/v0.1" },
    "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$" },
    "resourceUrn": {
      "type": "string",
      "pattern": "^urn:houston:([a-z][a-z0-9-]{0,62}):([a-z][a-z0-9-]{0,62}):([a-z][a-z0-9-]{0,62}):([a-z][a-z0-9._-]{1,127}):([A-Za-z0-9][A-Za-z0-9._~-]{0,127})$"
    },
    "fieldPath": { "type": "string", "pattern": "^(?:\\/(?:[^~/]|~[01])*)*$" },
    "locator": {
      "oneOf": [
        {
          "type": "object",
          "properties": { "kind": { "type": "string", "const": "row_field" } },
          "required": ["kind"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": { "type": "string", "const": "json_pointer" },
            "pointer": { "type": "string", "pattern": "^(?:\\/(?:[^~/]|~[01])*)*$" }
          },
          "required": ["kind", "pointer"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "start": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
            "end": { "type": "integer", "exclusiveMinimum": 0, "maximum": 9007199254740991 },
            "kind": { "type": "string", "const": "text_span" }
          },
          "required": ["start", "end", "kind"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": { "type": "string", "const": "image_region" },
            "x": { "type": "number", "minimum": 0, "maximum": 1 },
            "y": { "type": "number", "minimum": 0, "maximum": 1 },
            "widthWithinRemainder": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
            "heightWithinRemainder": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 }
          },
          "required": ["kind", "x", "y", "widthWithinRemainder", "heightWithinRemainder"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": { "type": "string", "const": "page" },
            "page": { "type": "integer", "exclusiveMinimum": 0, "maximum": 9007199254740991 },
            "endPage": { "type": "integer", "exclusiveMinimum": 0, "maximum": 9007199254740991 }
          },
          "required": ["kind", "page"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": { "type": "string", "const": "document_heading" },
            "headingPath": {
              "minItems": 1,
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          },
          "required": ["kind", "headingPath"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": { "type": "string", "const": "transcript_timecode" },
            "startMs": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
            "endMs": { "type": "integer", "exclusiveMinimum": 0, "maximum": 9007199254740991 },
            "speaker": { "type": "string", "minLength": 1 }
          },
          "required": ["kind", "startMs", "endMs"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": { "type": "string", "const": "speaker_turn" },
            "turn": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
            "speaker": { "type": "string", "minLength": 1 }
          },
          "required": ["kind", "turn"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "kind": { "type": "string", "const": "video_frame_range" },
            "startMs": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
            "endMs": { "type": "integer", "exclusiveMinimum": 0, "maximum": 9007199254740991 }
          },
          "required": ["kind", "startMs", "endMs"],
          "additionalProperties": false
        }
      ]
    },
    "modality": {
      "type": "string",
      "enum": ["text", "image", "document", "audio", "video", "structured_data", "mixed"]
    },
    "contentHash": { "type": "string", "pattern": "^(?:sha256:)?[a-f0-9]{64}$" },
    "ordinal": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
    "sourceVersion": { "type": "string", "minLength": 1 },
    "state": { "type": "string", "enum": ["active", "superseded", "tombstoned", "purged", "error"] }
  },
  "required": [
    "schemaVersion",
    "id",
    "resourceUrn",
    "fieldPath",
    "modality",
    "contentHash",
    "ordinal",
    "sourceVersion",
    "state"
  ],
  "additionalProperties": false
}
