{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "oneOf": [
    {
      "type": "object",
      "properties": { "kind": { "type": "string", "const": "row_field" } },
      "required": ["kind"],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "kind": { "type": "string", "const": "json_pointer" },
        "pointer": { "type": "string", "pattern": "^(?:\\/(?:[^~/]|~[01])*)*$" }
      },
      "required": ["kind", "pointer"],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "start": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
        "end": { "type": "integer", "exclusiveMinimum": 0, "maximum": 9007199254740991 },
        "kind": { "type": "string", "const": "text_span" }
      },
      "required": ["start", "end", "kind"],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "kind": { "type": "string", "const": "image_region" },
        "x": { "type": "number", "minimum": 0, "maximum": 1 },
        "y": { "type": "number", "minimum": 0, "maximum": 1 },
        "widthWithinRemainder": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
        "heightWithinRemainder": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 }
      },
      "required": ["kind", "x", "y", "widthWithinRemainder", "heightWithinRemainder"],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "kind": { "type": "string", "const": "page" },
        "page": { "type": "integer", "exclusiveMinimum": 0, "maximum": 9007199254740991 },
        "endPage": { "type": "integer", "exclusiveMinimum": 0, "maximum": 9007199254740991 }
      },
      "required": ["kind", "page"],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "kind": { "type": "string", "const": "document_heading" },
        "headingPath": {
          "minItems": 1,
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "required": ["kind", "headingPath"],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "kind": { "type": "string", "const": "transcript_timecode" },
        "startMs": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
        "endMs": { "type": "integer", "exclusiveMinimum": 0, "maximum": 9007199254740991 },
        "speaker": { "type": "string", "minLength": 1 }
      },
      "required": ["kind", "startMs", "endMs"],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "kind": { "type": "string", "const": "speaker_turn" },
        "turn": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
        "speaker": { "type": "string", "minLength": 1 }
      },
      "required": ["kind", "turn"],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "kind": { "type": "string", "const": "video_frame_range" },
        "startMs": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
        "endMs": { "type": "integer", "exclusiveMinimum": 0, "maximum": 9007199254740991 }
      },
      "required": ["kind", "startMs", "endMs"],
      "additionalProperties": false
    }
  ]
}
