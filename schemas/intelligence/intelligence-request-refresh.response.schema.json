{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "anyOf": [
    {
      "type": "object",
      "properties": {
        "requestId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$" },
        "data": {
          "type": "object",
          "properties": {
            "receiptId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$" },
            "state": {
              "type": "string",
              "enum": ["accepted", "pending_approval", "queued", "completed", "rejected"]
            },
            "approvalId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$" },
            "auditId": { "type": "string", "minLength": 1 },
            "idempotencyKey": { "type": "string", "minLength": 1 }
          },
          "required": ["receiptId", "state", "auditId", "idempotencyKey"],
          "additionalProperties": false
        },
        "warnings": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      },
      "required": ["requestId", "data"],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "requestId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$" },
        "error": {
          "type": "object",
          "properties": {
            "code": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{1,127}$" },
            "message": { "type": "string", "minLength": 1 },
            "retryable": { "type": "boolean" },
            "field": { "type": "string", "pattern": "^(?:\\/(?:[^~/]|~[01])*)*$" },
            "details": {
              "type": "object",
              "propertyNames": { "type": "string" },
              "additionalProperties": { "$ref": "#/$defs/__schema0" }
            }
          },
          "required": ["code", "message", "retryable"],
          "additionalProperties": false
        }
      },
      "required": ["requestId", "error"],
      "additionalProperties": false
    }
  ],
  "$defs": {
    "__schema0": {
      "anyOf": [
        { "type": "string" },
        { "type": "number" },
        { "type": "boolean" },
        { "type": "null" },
        { "type": "array", "items": { "$ref": "#/$defs/__schema0" } },
        {
          "type": "object",
          "propertyNames": { "type": "string" },
          "additionalProperties": { "$ref": "#/$defs/__schema0" }
        }
      ]
    }
  }
}
