{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": { "type": "string", "format": "uri" },
    "schemaVersion": { "type": "string", "const": "houston.dev/intelligence-manifest/v0.1" },
    "kind": { "type": "string", "const": "IntelligenceManifest" },
    "metadata": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{1,127}$" },
        "issuerId": { "type": "string", "pattern": "^[a-z][a-z0-9-]{0,62}$" },
        "app": { "type": "string", "pattern": "^[a-z][a-z0-9-]{0,62}$" },
        "environment": { "type": "string", "pattern": "^[a-z][a-z0-9-]{0,62}$" },
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?$" },
        "owner": { "type": "string", "minLength": 1 },
        "generatedAt": {
          "type": "string",
          "format": "date-time",
          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
        }
      },
      "required": ["id", "issuerId", "app", "environment", "version", "owner", "generatedAt"],
      "additionalProperties": false
    },
    "resourceTypes": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "key": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{1,127}$" },
          "urnResourceType": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{1,127}$" },
          "app": { "type": "string", "pattern": "^[a-z][a-z0-9-]{0,62}$" },
          "source": {
            "type": "object",
            "properties": {
              "adapter": {
                "type": "string",
                "enum": ["postgres", "convex", "filesystem", "object_storage", "external_api"]
              },
              "schema": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{1,127}$" },
              "table": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{1,127}$" },
              "collection": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{1,127}$" },
              "bucket": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{1,127}$" },
              "primaryKey": { "type": "string", "minLength": 1 },
              "changeMode": {
                "type": "string",
                "enum": ["transactional", "webhook", "reconciliation", "manual"]
              }
            },
            "required": ["adapter", "primaryKey", "changeMode"],
            "additionalProperties": false
          },
          "tenant": {
            "type": "object",
            "properties": {
              "resolver": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{1,127}$" },
              "field": { "type": "string", "pattern": "^(?:\\/(?:[^~/]|~[01])*)*$" }
            },
            "required": ["resolver"],
            "additionalProperties": false
          },
          "defaultPolicyRef": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{1,127}$" },
          "lifecycle": { "type": "string", "enum": ["experimental", "active", "deprecated"] },
          "relations": {
            "type": "array",
            "items": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{1,127}$" }
          },
          "deletion": {
            "type": "string",
            "enum": ["cascade_derived", "retain_tombstone", "app_managed"]
          },
          "manifestVersion": { "type": "string", "minLength": 1 },
          "owner": { "type": "string", "minLength": 1 }
        },
        "required": [
          "key",
          "urnResourceType",
          "app",
          "source",
          "tenant",
          "defaultPolicyRef",
          "lifecycle",
          "relations",
          "deletion",
          "manifestVersion",
          "owner"
        ],
        "additionalProperties": false
      }
    },
    "fieldDefinitions": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "resourceType": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{1,127}$" },
          "fieldPath": { "type": "string", "pattern": "^(?:\\/(?:[^~/]|~[01])*)*$" },
          "semanticType": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{1,127}$" },
          "aliases": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "sensitivity": {
            "type": "string",
            "enum": [
              "public",
              "workspace_private",
              "client_confidential",
              "restricted",
              "prohibited_from_ai"
            ]
          },
          "index": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["exact", "lexical", "semantic", "faceted", "relationship"]
            }
          },
          "pipeline": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{1,127}$" },
          "retentionDays": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          },
          "modelPolicy": {
            "type": "string",
            "enum": ["local_only", "redacted_cloud", "allowed_cloud", "no_ai"]
          },
          "excluded": { "default": false, "type": "boolean" }
        },
        "required": [
          "resourceType",
          "fieldPath",
          "semanticType",
          "aliases",
          "sensitivity",
          "index",
          "modelPolicy",
          "excluded"
        ],
        "additionalProperties": false
      }
    },
    "policies": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "schemaVersion": { "type": "string", "const": "houston.dev/intelligence/v0.1" },
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{1,127}$" },
          "version": { "type": "string", "minLength": 1 },
          "sensitivity": {
            "type": "string",
            "enum": [
              "public",
              "workspace_private",
              "client_confidential",
              "restricted",
              "prohibited_from_ai"
            ]
          },
          "accessResolver": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{1,127}$" },
          "modelPolicy": {
            "type": "string",
            "enum": ["local_only", "redacted_cloud", "allowed_cloud", "no_ai"]
          },
          "allowedPurposes": {
            "minItems": 1,
            "type": "array",
            "items": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{1,127}$" }
          },
          "consent": { "type": "string", "enum": ["not_required", "required", "verified"] },
          "retention": {
            "type": "object",
            "properties": {
              "days": { "type": "integer", "exclusiveMinimum": 0, "maximum": 9007199254740991 },
              "legalHoldAware": { "type": "boolean" }
            },
            "required": ["legalHoldAware"],
            "additionalProperties": false
          },
          "deletionBehavior": {
            "type": "string",
            "enum": ["cascade", "cryptographic_erasure", "tombstone_then_purge"]
          }
        },
        "required": [
          "schemaVersion",
          "id",
          "version",
          "sensitivity",
          "accessResolver",
          "modelPolicy",
          "allowedPurposes",
          "consent",
          "retention",
          "deletionBehavior"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "schemaVersion",
    "kind",
    "metadata",
    "resourceTypes",
    "fieldDefinitions",
    "policies"
  ],
  "additionalProperties": false
}
