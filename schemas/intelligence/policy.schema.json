{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schemaVersion": { "type": "string", "const": "houston.dev/intelligence/v0.1" },
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{1,127}$" },
    "version": { "type": "string", "minLength": 1 },
    "sensitivity": {
      "type": "string",
      "enum": [
        "public",
        "workspace_private",
        "client_confidential",
        "restricted",
        "prohibited_from_ai"
      ]
    },
    "accessResolver": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{1,127}$" },
    "modelPolicy": {
      "type": "string",
      "enum": ["local_only", "redacted_cloud", "allowed_cloud", "no_ai"]
    },
    "allowedPurposes": {
      "minItems": 1,
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{1,127}$" }
    },
    "consent": { "type": "string", "enum": ["not_required", "required", "verified"] },
    "retention": {
      "type": "object",
      "properties": {
        "days": { "type": "integer", "exclusiveMinimum": 0, "maximum": 9007199254740991 },
        "legalHoldAware": { "type": "boolean" }
      },
      "required": ["legalHoldAware"],
      "additionalProperties": false
    },
    "deletionBehavior": {
      "type": "string",
      "enum": ["cascade", "cryptographic_erasure", "tombstone_then_purge"]
    }
  },
  "required": [
    "schemaVersion",
    "id",
    "version",
    "sensitivity",
    "accessResolver",
    "modelPolicy",
    "allowedPurposes",
    "consent",
    "retention",
    "deletionBehavior"
  ],
  "additionalProperties": false
}
