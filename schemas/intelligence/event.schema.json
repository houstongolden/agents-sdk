{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schemaVersion": { "type": "string", "const": "houston.dev/intelligence/v0.1" },
    "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$" },
    "type": {
      "type": "string",
      "enum": ["source_created", "source_updated", "source_deleted", "policy_changed", "reconcile"]
    },
    "resourceUrn": {
      "type": "string",
      "pattern": "^urn:agents-sdk:([a-z][a-z0-9-]{0,62}):([a-z][a-z0-9-]{0,62}):([a-z][a-z0-9-]{0,62}):([a-z][a-z0-9._-]{1,127}):([A-Za-z0-9][A-Za-z0-9._~-]{0,127})$"
    },
    "sourceVersion": { "type": "string", "minLength": 1 },
    "sourceHash": { "type": "string", "pattern": "^(?:sha256:)?[a-f0-9]{64}$" },
    "changedFieldPaths": {
      "type": "array",
      "items": { "type": "string", "pattern": "^(?:\\/(?:[^~/]|~[01])*)*$" }
    },
    "policyVersion": { "type": "string", "minLength": 1 },
    "idempotencyKey": { "type": "string", "minLength": 1 },
    "producer": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{1,127}$" },
    "occurredAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
    },
    "receivedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
    }
  },
  "required": [
    "schemaVersion",
    "id",
    "type",
    "resourceUrn",
    "sourceVersion",
    "changedFieldPaths",
    "policyVersion",
    "idempotencyKey",
    "producer",
    "occurredAt",
    "receivedAt"
  ],
  "additionalProperties": false
}
