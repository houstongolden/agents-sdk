{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schemaVersion": { "type": "string", "const": "houston.dev/intelligence/v0.1" },
    "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$" },
    "from": {
      "type": "object",
      "properties": {
        "resourceUrn": {
          "type": "string",
          "pattern": "^urn:agents-sdk:([a-z][a-z0-9-]{0,62}):([a-z][a-z0-9-]{0,62}):([a-z][a-z0-9-]{0,62}):([a-z][a-z0-9._-]{1,127}):([A-Za-z0-9][A-Za-z0-9._~-]{0,127})$"
        },
        "fragmentId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$" },
        "enrichmentId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$" },
        "fieldPath": { "type": "string", "pattern": "^(?:\\/(?:[^~/]|~[01])*)*$" }
      },
      "required": ["resourceUrn"],
      "additionalProperties": false
    },
    "to": {
      "type": "object",
      "properties": {
        "resourceUrn": {
          "type": "string",
          "pattern": "^urn:agents-sdk:([a-z][a-z0-9-]{0,62}):([a-z][a-z0-9-]{0,62}):([a-z][a-z0-9-]{0,62}):([a-z][a-z0-9._-]{1,127}):([A-Za-z0-9][A-Za-z0-9._~-]{0,127})$"
        },
        "fragmentId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$" },
        "enrichmentId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$" },
        "fieldPath": { "type": "string", "pattern": "^(?:\\/(?:[^~/]|~[01])*)*$" }
      },
      "required": ["resourceUrn"],
      "additionalProperties": false
    },
    "type": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{1,127}$" },
    "direction": { "type": "string", "enum": ["directed", "bidirectional"] },
    "evidenceRefs": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "resourceUrn": {
            "type": "string",
            "pattern": "^urn:agents-sdk:([a-z][a-z0-9-]{0,62}):([a-z][a-z0-9-]{0,62}):([a-z][a-z0-9-]{0,62}):([a-z][a-z0-9._-]{1,127}):([A-Za-z0-9][A-Za-z0-9._~-]{0,127})$"
          },
          "fragmentId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$" },
          "enrichmentId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$" },
          "fieldPath": { "type": "string", "pattern": "^(?:\\/(?:[^~/]|~[01])*)*$" }
        },
        "required": ["resourceUrn"],
        "additionalProperties": false
      }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "validFrom": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
    },
    "validTo": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
    },
    "state": { "type": "string", "enum": ["candidate", "active", "superseded", "rejected"] }
  },
  "required": [
    "schemaVersion",
    "id",
    "from",
    "to",
    "type",
    "direction",
    "evidenceRefs",
    "confidence",
    "state"
  ],
  "additionalProperties": false
}
