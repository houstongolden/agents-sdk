{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "actor": {
      "type": "object",
      "properties": {
        "actorId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$" },
        "app": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{1,127}$" },
        "audience": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{1,127}$" },
        "tenantId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$" },
        "workspaceId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$" },
        "clientId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$" },
        "scopes": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      },
      "required": ["actorId", "app", "audience", "tenantId", "scopes"],
      "additionalProperties": false
    },
    "idempotencyKey": { "type": "string", "minLength": 1 },
    "reason": { "type": "string", "minLength": 1 },
    "proposalId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$" },
    "expectedVersion": { "type": "string", "minLength": 1 }
  },
  "required": ["actor", "idempotencyKey", "reason", "proposalId", "expectedVersion"],
  "additionalProperties": false
}
