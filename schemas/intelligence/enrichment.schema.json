{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schemaVersion": { "type": "string", "const": "houston.dev/intelligence/v0.1" },
    "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$" },
    "target": {
      "type": "object",
      "properties": {
        "resourceUrn": {
          "type": "string",
          "pattern": "^urn:agents-sdk:([a-z][a-z0-9-]{0,62}):([a-z][a-z0-9-]{0,62}):([a-z][a-z0-9-]{0,62}):([a-z][a-z0-9._-]{1,127}):([A-Za-z0-9][A-Za-z0-9._~-]{0,127})$"
        },
        "fragmentId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$" },
        "enrichmentId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$" },
        "fieldPath": { "type": "string", "pattern": "^(?:\\/(?:[^~/]|~[01])*)*$" }
      },
      "required": ["resourceUrn"],
      "additionalProperties": false
    },
    "kind": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{1,127}$" },
    "value": { "$ref": "#/$defs/__schema0" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "model": { "type": "string", "minLength": 1 },
    "modelVersion": { "type": "string", "minLength": 1 },
    "promptVersion": { "type": "string", "minLength": 1 },
    "outputSchemaVersion": { "type": "string", "minLength": 1 },
    "provenance": {
      "type": "object",
      "properties": {
        "sourceVersion": { "type": "string", "minLength": 1 },
        "sourceHash": { "type": "string", "pattern": "^(?:sha256:)?[a-f0-9]{64}$" },
        "pipeline": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{1,127}$" },
        "pipelineVersion": { "type": "string", "minLength": 1 },
        "producedAt": {
          "type": "string",
          "format": "date-time",
          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
        },
        "evidenceRefs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "resourceUrn": {
                "type": "string",
                "pattern": "^urn:agents-sdk:([a-z][a-z0-9-]{0,62}):([a-z][a-z0-9-]{0,62}):([a-z][a-z0-9-]{0,62}):([a-z][a-z0-9._-]{1,127}):([A-Za-z0-9][A-Za-z0-9._~-]{0,127})$"
              },
              "fragmentId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$" },
              "enrichmentId": {
                "type": "string",
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$"
              },
              "fieldPath": { "type": "string", "pattern": "^(?:\\/(?:[^~/]|~[01])*)*$" }
            },
            "required": ["resourceUrn"],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "sourceVersion",
        "sourceHash",
        "pipeline",
        "pipelineVersion",
        "producedAt",
        "evidenceRefs"
      ],
      "additionalProperties": false
    },
    "state": {
      "type": "string",
      "enum": ["draft", "validated", "published", "superseded", "quarantined", "failed"]
    }
  },
  "required": [
    "schemaVersion",
    "id",
    "target",
    "kind",
    "value",
    "confidence",
    "model",
    "modelVersion",
    "promptVersion",
    "outputSchemaVersion",
    "provenance",
    "state"
  ],
  "additionalProperties": false,
  "$defs": {
    "__schema0": {
      "anyOf": [
        { "type": "string" },
        { "type": "number" },
        { "type": "boolean" },
        { "type": "null" },
        { "type": "array", "items": { "$ref": "#/$defs/__schema0" } },
        {
          "type": "object",
          "propertyNames": { "type": "string" },
          "additionalProperties": { "$ref": "#/$defs/__schema0" }
        }
      ]
    }
  }
}
