{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "anyOf": [
    {
      "type": "object",
      "properties": {
        "requestId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$" },
        "data": {
          "type": "object",
          "properties": {
            "queryId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$" },
            "evidencePacks": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$" },
                  "queryId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$" },
                  "citations": {
                    "minItems": 1,
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string",
                          "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$"
                        },
                        "resourceUrn": {
                          "type": "string",
                          "pattern": "^urn:agents-sdk:([a-z][a-z0-9-]{0,62}):([a-z][a-z0-9-]{0,62}):([a-z][a-z0-9-]{0,62}):([a-z][a-z0-9._-]{1,127}):([A-Za-z0-9][A-Za-z0-9._~-]{0,127})$"
                        },
                        "fragmentId": {
                          "type": "string",
                          "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$"
                        },
                        "fieldPath": { "type": "string", "pattern": "^(?:\\/(?:[^~/]|~[01])*)*$" },
                        "locator": {
                          "oneOf": [
                            {
                              "type": "object",
                              "properties": { "kind": { "type": "string", "const": "row_field" } },
                              "required": ["kind"],
                              "additionalProperties": false
                            },
                            {
                              "type": "object",
                              "properties": {
                                "kind": { "type": "string", "const": "json_pointer" },
                                "pointer": {
                                  "type": "string",
                                  "pattern": "^(?:\\/(?:[^~/]|~[01])*)*$"
                                }
                              },
                              "required": ["kind", "pointer"],
                              "additionalProperties": false
                            },
                            {
                              "type": "object",
                              "properties": {
                                "start": {
                                  "type": "integer",
                                  "minimum": 0,
                                  "maximum": 9007199254740991
                                },
                                "end": {
                                  "type": "integer",
                                  "exclusiveMinimum": 0,
                                  "maximum": 9007199254740991
                                },
                                "kind": { "type": "string", "const": "text_span" }
                              },
                              "required": ["start", "end", "kind"],
                              "additionalProperties": false
                            },
                            {
                              "type": "object",
                              "properties": {
                                "kind": { "type": "string", "const": "image_region" },
                                "x": { "type": "number", "minimum": 0, "maximum": 1 },
                                "y": { "type": "number", "minimum": 0, "maximum": 1 },
                                "widthWithinRemainder": {
                                  "type": "number",
                                  "exclusiveMinimum": 0,
                                  "maximum": 1
                                },
                                "heightWithinRemainder": {
                                  "type": "number",
                                  "exclusiveMinimum": 0,
                                  "maximum": 1
                                }
                              },
                              "required": [
                                "kind",
                                "x",
                                "y",
                                "widthWithinRemainder",
                                "heightWithinRemainder"
                              ],
                              "additionalProperties": false
                            },
                            {
                              "type": "object",
                              "properties": {
                                "kind": { "type": "string", "const": "page" },
                                "page": {
                                  "type": "integer",
                                  "exclusiveMinimum": 0,
                                  "maximum": 9007199254740991
                                },
                                "endPage": {
                                  "type": "integer",
                                  "exclusiveMinimum": 0,
                                  "maximum": 9007199254740991
                                }
                              },
                              "required": ["kind", "page"],
                              "additionalProperties": false
                            },
                            {
                              "type": "object",
                              "properties": {
                                "kind": { "type": "string", "const": "document_heading" },
                                "headingPath": {
                                  "minItems": 1,
                                  "type": "array",
                                  "items": { "type": "string", "minLength": 1 }
                                }
                              },
                              "required": ["kind", "headingPath"],
                              "additionalProperties": false
                            },
                            {
                              "type": "object",
                              "properties": {
                                "kind": { "type": "string", "const": "transcript_timecode" },
                                "startMs": {
                                  "type": "integer",
                                  "minimum": 0,
                                  "maximum": 9007199254740991
                                },
                                "endMs": {
                                  "type": "integer",
                                  "exclusiveMinimum": 0,
                                  "maximum": 9007199254740991
                                },
                                "speaker": { "type": "string", "minLength": 1 }
                              },
                              "required": ["kind", "startMs", "endMs"],
                              "additionalProperties": false
                            },
                            {
                              "type": "object",
                              "properties": {
                                "kind": { "type": "string", "const": "speaker_turn" },
                                "turn": {
                                  "type": "integer",
                                  "minimum": 0,
                                  "maximum": 9007199254740991
                                },
                                "speaker": { "type": "string", "minLength": 1 }
                              },
                              "required": ["kind", "turn"],
                              "additionalProperties": false
                            },
                            {
                              "type": "object",
                              "properties": {
                                "kind": { "type": "string", "const": "video_frame_range" },
                                "startMs": {
                                  "type": "integer",
                                  "minimum": 0,
                                  "maximum": 9007199254740991
                                },
                                "endMs": {
                                  "type": "integer",
                                  "exclusiveMinimum": 0,
                                  "maximum": 9007199254740991
                                }
                              },
                              "required": ["kind", "startMs", "endMs"],
                              "additionalProperties": false
                            }
                          ]
                        },
                        "snippet": { "type": "string", "maxLength": 4000 },
                        "previewUri": { "type": "string", "format": "uri" },
                        "score": {
                          "type": "object",
                          "properties": {
                            "exact": { "type": "number", "minimum": 0 },
                            "lexical": { "type": "number", "minimum": 0 },
                            "semantic": { "type": "number", "minimum": 0 },
                            "relationship": { "type": "number", "minimum": 0 },
                            "recency": { "type": "number", "minimum": 0 },
                            "feedback": { "type": "number", "minimum": 0 },
                            "fused": { "type": "number", "minimum": 0 }
                          },
                          "required": ["fused"],
                          "additionalProperties": false
                        },
                        "sourceVersion": { "type": "string", "minLength": 1 },
                        "enrichmentVersion": { "type": "string", "minLength": 1 },
                        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
                        "policyDecisionId": { "type": "string", "minLength": 1 },
                        "retrievedAt": {
                          "type": "string",
                          "format": "date-time",
                          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
                        }
                      },
                      "required": [
                        "id",
                        "resourceUrn",
                        "fieldPath",
                        "score",
                        "sourceVersion",
                        "confidence",
                        "policyDecisionId",
                        "retrievedAt"
                      ],
                      "additionalProperties": false
                    }
                  },
                  "conflicts": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "citationIds": {
                          "minItems": 2,
                          "type": "array",
                          "items": {
                            "type": "string",
                            "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$"
                          }
                        },
                        "reason": { "type": "string", "minLength": 1 }
                      },
                      "required": ["citationIds", "reason"],
                      "additionalProperties": false
                    }
                  },
                  "warnings": { "type": "array", "items": { "type": "string", "minLength": 1 } }
                },
                "required": ["id", "queryId", "citations", "conflicts", "warnings"],
                "additionalProperties": false
              }
            }
          },
          "required": ["queryId", "evidencePacks"],
          "additionalProperties": false
        },
        "warnings": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "page": {
          "type": "object",
          "properties": {
            "nextCursor": { "type": "string", "minLength": 1 },
            "hasMore": { "type": "boolean" }
          },
          "required": ["hasMore"],
          "additionalProperties": false
        }
      },
      "required": ["requestId", "data", "page"],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "requestId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$" },
        "error": {
          "type": "object",
          "properties": {
            "code": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{1,127}$" },
            "message": { "type": "string", "minLength": 1 },
            "retryable": { "type": "boolean" },
            "field": { "type": "string", "pattern": "^(?:\\/(?:[^~/]|~[01])*)*$" },
            "details": {
              "type": "object",
              "propertyNames": { "type": "string" },
              "additionalProperties": { "$ref": "#/$defs/__schema0" }
            }
          },
          "required": ["code", "message", "retryable"],
          "additionalProperties": false
        }
      },
      "required": ["requestId", "error"],
      "additionalProperties": false
    }
  ],
  "$defs": {
    "__schema0": {
      "anyOf": [
        { "type": "string" },
        { "type": "number" },
        { "type": "boolean" },
        { "type": "null" },
        { "type": "array", "items": { "$ref": "#/$defs/__schema0" } },
        {
          "type": "object",
          "propertyNames": { "type": "string" },
          "additionalProperties": { "$ref": "#/$defs/__schema0" }
        }
      ]
    }
  }
}
