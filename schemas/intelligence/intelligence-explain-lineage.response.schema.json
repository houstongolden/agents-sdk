{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "anyOf": [
    {
      "type": "object",
      "properties": {
        "requestId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$" },
        "data": {
          "type": "object",
          "properties": {
            "nodes": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": { "type": "string", "minLength": 1 },
                  "kind": {
                    "type": "string",
                    "enum": ["source", "fragment", "enrichment", "embedding", "fact", "edge", "job"]
                  },
                  "version": { "type": "string", "minLength": 1 },
                  "state": { "type": "string", "minLength": 1 }
                },
                "required": ["id", "kind", "version", "state"],
                "additionalProperties": false
              }
            },
            "edges": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "from": { "type": "string", "minLength": 1 },
                  "to": { "type": "string", "minLength": 1 },
                  "relation": { "type": "string", "minLength": 1 }
                },
                "required": ["from", "to", "relation"],
                "additionalProperties": false
              }
            }
          },
          "required": ["nodes", "edges"],
          "additionalProperties": false
        },
        "warnings": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      },
      "required": ["requestId", "data"],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "requestId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$" },
        "error": {
          "type": "object",
          "properties": {
            "code": { "type": "string", "pattern": "^[a-z][a-z0-9._-]{1,127}$" },
            "message": { "type": "string", "minLength": 1 },
            "retryable": { "type": "boolean" },
            "field": { "type": "string", "pattern": "^(?:\\/(?:[^~/]|~[01])*)*$" },
            "details": {
              "type": "object",
              "propertyNames": { "type": "string" },
              "additionalProperties": { "$ref": "#/$defs/__schema0" }
            }
          },
          "required": ["code", "message", "retryable"],
          "additionalProperties": false
        }
      },
      "required": ["requestId", "error"],
      "additionalProperties": false
    }
  ],
  "$defs": {
    "__schema0": {
      "anyOf": [
        { "type": "string" },
        { "type": "number" },
        { "type": "boolean" },
        { "type": "null" },
        { "type": "array", "items": { "$ref": "#/$defs/__schema0" } },
        {
          "type": "object",
          "propertyNames": { "type": "string" },
          "additionalProperties": { "$ref": "#/$defs/__schema0" }
        }
      ]
    }
  }
}
