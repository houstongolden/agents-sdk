{
  "schemaVersion": "youstack/v1",
  "kind": "youstack",
  "slug": "agents-sdk",
  "name": "Agents SDK",
  "domain": "agent-application-development",
  "aliases": ["agents-sdk.com", "agentsdk", "agenty", "agent-app-components"],
  "tags": ["agents", "components", "developer-tools", "ui", "mcp", "templates"],
  "version": "0.1.0",
  "description": "The open-source component system for building production agentic applications.",
  "visibility": "private",
  "owner": { "name": "Houston Golden", "profile": "https://you.md/houstongolden" },
  "compatibility": {
    "hosts": ["claude-code", "codex", "cursor"],
    "requiresYoumdApi": false,
    "requiresYoumdMcp": false
  },
  "brainScopes": [
    {
      "scope": "identity.public.read",
      "required": false,
      "reason": "Adapt approved public author context without embedding private identity data."
    },
    {
      "scope": "preferences.agent.read",
      "required": false,
      "reason": "Apply owner-approved collaboration preferences at runtime."
    }
  ],
  "files": [
    { "path": "AGENTS.md", "type": "instructions", "required": true },
    { "path": "project-context/plan.md", "type": "workflow", "required": true },
    { "path": "project-context/ACCEPTANCE.md", "type": "test", "required": true },
    { "path": "README.md", "type": "docs", "required": true },
    { "path": "DESIGN.md", "type": "docs", "required": true }
  ],
  "adapters": {
    "claude-code": { "files": ["CLAUDE.md"], "bootstrap": "CLAUDE.md" },
    "codex": { "files": ["AGENTS.md"], "bootstrap": "AGENTS.md" },
    "cursor": { "files": ["AGENTS.md"], "bootstrap": "AGENTS.md" }
  },
  "capabilities": [
    {
      "id": "design-registry-item",
      "intent": "Turn a production-proven agent application pattern into an attributed, documented, tested registry item.",
      "localOnly": true,
      "mutationPolicy": "read_only"
    },
    {
      "id": "install-registry-item",
      "intent": "Copy a selected Agents SDK component, pattern, or template into a developer-owned application with conflict checks.",
      "localOnly": true,
      "mutationPolicy": "fs_write"
    },
    {
      "id": "verify-registry-item",
      "intent": "Run source, documentation, security, accessibility, and behavior checks and emit evidence.",
      "localOnly": true,
      "mutationPolicy": "read_only"
    }
  ],
  "accessPolicy": {
    "defaultMode": "local_static",
    "protectedByDefault": true,
    "requiresApprovalFor": [
      "private_context.read",
      "connected_tool.write",
      "remote_repo.write",
      "publish_public"
    ],
    "secretPolicy": "env_only"
  },
  "safety": {
    "tier": "T1",
    "fs_write": true,
    "network": true,
    "shell": true,
    "auto_pr": false,
    "humanGate": {
      "required": false,
      "for": []
    }
  },
  "sharing": {
    "allowedModes": ["private", "scoped-link", "public-open"],
    "defaultMode": "private"
  },
  "repoSync": { "enabled": false, "provider": "github", "path": "." },
  "improvement": {
    "mode": "propose",
    "cadence": "after meaningful production-agent work and scheduled portfolio audits",
    "signals": [
      "usage",
      "failures",
      "user corrections",
      "eval regressions",
      "provenance proposals"
    ],
    "evals": [
      "pnpm validate",
      "clean-directory registry acceptance proof",
      "youmd stack smoke --path youstack.json"
    ],
    "appliesTo": [
      "components",
      "agents-skills",
      "tools-mcp",
      "patterns",
      "templates",
      "examples",
      "cli",
      "docs"
    ],
    "approvalRequiredFor": [
      "private_context.read",
      "connected_tool.write",
      "remote_repo.write",
      "publish_public"
    ]
  },
  "update": {
    "channel": "manual",
    "check": "pnpm validate",
    "source": "user-owned Agents SDK repository",
    "autoApply": false
  }
}
